songn=""
full_lyrics=""
artist1=""


genius.timeout = 15
genius.retries = 3
def getlyr():
    global songn,artist1
    print("enter the song name")
    songn=input()
    print("enter the artist name ")
    artist1=input()
    lyr=genius.search_song(songn,artist=artist1)
    with open ("lyrics.txt","w",encoding="utf-8") as f:
        f.write(lyr.lyrics)

def cleaner():
    with open('lyrics.txt',"r",encoding="utf-8") as f:
        lyricss=f.read()
        lyrc=clean(
              
            lyricss,
            fix_unicode=True,       
            to_ascii=True,          
            lower=False,             
            no_line_breaks=False, 
            no_urls=True,         
            no_emails=True,       
            no_phone_numbers=True,
            no_numbers=False,     
            no_digits=False,      
            no_currency_symbols=True,
            no_punct=False     
              )
        
        with open ("lyricscleaned.text","w",encoding="utf-8")as file:
            file.write(lyrc)
getlyr()
cleaner()
def analyzefullsong():
